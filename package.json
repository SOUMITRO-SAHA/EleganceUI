{
  "name": "elegance-ui",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "vitest"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "dotenv-checker": "^1.1.5",
    "jest-diff": "^29.7.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.1.1",
    "tsc-absolute": "^1.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2",
    "vitest-fetch-mock": "^0.2.2",
    "vitest-mock-extended": "^1.3.1"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@types/jsdom": "^21.1.6",
    "eslint": "^8.56.0",
    "lucide-react": "^0.323.0",
    "turbo": "latest"
  },
  "lint-staged": {
    "(apps|packages)/**/*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ],
    "packages/prisma/schema.prisma": [
      "prisma format"
    ]
  },
  "resolutions": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18"
  },
  "packageManager": "pnpm@8.9.0",
  "engines": {
    "node": ">=18.x",
    "pnpm": ">=8.x"
  }
}